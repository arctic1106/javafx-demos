<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="coderunner.MainController" styleClass="main-container">
    <children>
        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox styleClass="input-section">
                            <children>
                                <Label text="Java File:" />
                                <HBox styleClass="file-selection-row">
                                    <children>
                                        <TextField fx:id="javaFileField" editable="false"
                                            promptText="Select a java file to run..."
                                            styleClass="fill-width" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="browseButton" mnemonicParsing="false"
                                            onAction="#handleBrowse" styleClass="secondary"
                                            text="Browse" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox styleClass="input-section">
                            <children>
                                <Label text="Command Line Arguments:" />
                                <HBox styleClass="args-input-row">
                                    <children>
                                        <TextField fx:id="argsField"
                                            promptText="Enter command line arguments (optional)..."
                                            styleClass="fill-width" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="runButton" mnemonicParsing="false"
                                            onAction="#handleRun" prefWidth="120.0"
                                            styleClass="primary" text="Run Script" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox styleClass="section-container" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Output:" />
                                <TextArea fx:id="outputArea" editable="false" prefHeight="300.0"
                                    wrapText="true" styleClass="grow-vertical" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox styleClass="section-container" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Code:" />
                                <HBox HBox.hgrow="ALWAYS" />
                                <Button fx:id="saveButton" mnemonicParsing="false"
                                    onAction="#handleSave" styleClass="secondary" text="Save" />
                                <Button fx:id="saveAsButton" mnemonicParsing="false"
                                    onAction="#handleSaveAs" styleClass="secondary" text="Save As" />
                            </children>
                        </HBox>
                        <TextArea fx:id="codeArea" editable="true" wrapText="false"
                            prefWidth="800.0" prefHeight="300.0" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </HBox>
        <Label fx:id="statusBarLabel" text="Ready" styleClass="status-bar" maxWidth="Infinity"
            alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="5.0" left="20.0" right="20.0" top="5.0" />
            </padding>
        </Label>
    </children>
</VBox>